FROM python:3.12-slim

WORKDIR /app

COPY requirements.txt requirements-ui.txt ./
RUN pip install --no-cache-dir -r requirements-ui.txt

COPY src ./src
COPY scripts/streamlit_app.py ./scripts/streamlit_app.py

ENTRYPOINT ["sh", "-c", "streamlit run scripts/streamlit_app.py --server.port ${PORT:-8501} --server.address 0.0.0.0"]
