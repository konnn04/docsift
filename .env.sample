AI_PROVIDER_ORDER=gemini

GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-3-flash-preview
GEMINI_STORE_NAME=docsift-kb

# Gemini manages chunking automatically; these two values are NOT sent to
# the API. They only feed the "files/chunks embedded" log line as an
# estimate -- see README "Files/chunks embedded log" for why.
GEMINI_CHUNK_SIZE_ESTIMATE_TOKENS=800
GEMINI_CHUNK_OVERLAP_ESTIMATE_TOKENS=100

HELP_CENTER_BASE=https://support.optisigns.com
HELP_CENTER_LOCALE=en-us
MIN_ARTICLES=30
PAGE_SIZE=100

ARTICLES_DIR=data/articles
MANIFEST_PATH=data/manifest.json

REQUEST_TIMEOUT=20
SCRAPER_USER_AGENT=docsift-kb-bot/1.0 (+https://github.com/)
# DRY_RUN=true  # scrape + convert + diff, but skip real uploads (useful for testing)
# SMOKE_TEST_LIMIT=1  # cap scrape+upload to N articles (used by the CI smoke-test workflow)
